@model SHWalks.UI.Models.AreaViewModel;

@{
    ViewData["Title"] = Model.Name + "Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <a asp-action="Index" class="btn btn-outline-secondary mb-3">&larr; Back to Areas</a>

            <div class="card shadow-lg border-0 rounded-end overflow-hidden">
                <div style="align-items: center;">
                    <img src="@Model.ImageUrl" class="img-fluid object-fit-cover rounded-1" alt="@Model.Name"
                         style="width: fit-content; max-height: 300px;">
                </div>

                <div class="card-body p-4">
                    <h1 class="display-4 fw-bold text-primary mb-3">@Model.Name</h1>

                    <p class="text-muted small">
                        <strong>System Database ID:</strong> @Model.Id
                    </p>

                    <hr class="my-4" />

                    <p class="lead">
                        Welcome to @Model.Name! This is a registered region inside the SHWalks application system.
                        Soon, you will be able to view all the walking paths associated with this beautiful neighborhood.
                    </p>

                    <div class="d-flex gap-2 mt-4">
                        <a class="btn btn-outline-success px-4"
                           asp-controller="Areas"
                           asp-action="Edit"
                           asp-route-id="@Model.Id">Edit Area Details</a>

                        <a asp-controller="Areas" 
                        asp-action="Delete"
                        asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

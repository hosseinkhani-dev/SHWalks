@model SHWalks.UI.Models.AreaViewModel;

@{
    ViewData["Title"] = Model.Name + "Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <a asp-action="Index" class="btn btn-outline-secondary mb-3">&larr; Back to Areas</a>

            <div class="card shadow-lg border-0 rounded-3 overflow-hidden">

                <img src="@Model.ImageUrl" class="img-fluid object-fit-cover" alt="@Model.Name" 
                style="width: 100%; max-height: 400px;">

                <div class="card-body p-4">
                    <h1 class="display-4 fw-bold text-primary mb-3">@Model.Name</h1>

                    <p class="text-muted small">
                        <strong>System Database ID:</strong> @Model.Id
                    </p>

                    <hr class="my-4" />

                    <p class="lead">
                        Welcome to @Model.Name! This is a registered region inside the SHWalks application system.
                        Soon, you will be able to view all the walking paths associated with this beautiful neighborhood.
                    </p>

                    <div class="d-flex gap-2 mt-4">
                        <a href="#" class="btn btn-warning px-4">Edit Area Details</a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@model SHWalks.UI.Models.Auth.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <div class="card shadow border-0 rounded p-4 bg-white">
                <div class="text-center mb-4">
                    <h1 class="h2 fw-bold text-dark mb-1">Join SHWalks</h1>
                    <p class="text-muted">Create an account to discover walking trails</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label fw-semibold text-secondary">Username</label>
                        <input asp-for="UserName" class="form-control" placeholder="Choose a userName" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold text-secondary">Password</label>
                        <input asp-for="Password" class="form-control" placeholder="Minimum 3 characters..." />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold text-secondary">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat your password..." />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold shadow-sm mb-3">Sign Up</button>

                    <div class="text-center">
                        <small class="text-muted">Already have an account? <a asp-action="Login" class="text-primary text-decoration-none fw-semibold">Log In</a></small>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
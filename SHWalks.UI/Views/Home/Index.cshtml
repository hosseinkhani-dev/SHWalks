@{
    ViewData["Title"] = "Home Dashboard";
}

<div class="bg-light rounded p-5 mb-4 border-0 shadow-sm position-relative overflow-hidden" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
    <div class="row align-items-center py-3">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold text-dark mb-2">Welcome to SHWalks</h1>
            <p class="fs-5 text-muted mb-4">A professional full-stack software application designed to track, explore, and manage stunning walking trails and regional geographical environments.</p>

            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Walks" asp-action="Index" class="btn btn-primary btn-lg px-4 fw-semibold shadow-sm">Explore Trails</a>
                @if (User.Identity == null || !User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Auth" asp-action="Register" class="btn btn-outline-secondary btn-lg px-4 fw-semibold">Create An Account</a>
                }
            </div>
        </div>
    </div>
</div>


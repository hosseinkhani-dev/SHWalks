@model SHWalks.UI.Models.AddAreaViewModel

@{
    ViewData["Title"] = "Add New Area";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow p-4 rounded bg-white">

            <h2 class="mb-4 text-success fw-bold">Add New Shiraz Area</h2>

            <form asp-action="Add" method="post">

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-label form-control" placeholder="e.g., Qasr-e Dasht" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ImageUrl" class="form-label fw-semibold"></label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success flex-grow-1">Save Area</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>

            </form>

        </div>
    </div>
</div>